# AI Trading Agents Platform - Environment Configuration
# Copy to .env: cp .env.example .env
# Works immediately for the random agent. Uncomment and fill keys for LLM/Claude agents.

# ============================================================
# Swiftward Image (pre-built, pulled automatically)
# Single image: migrations, load-policies, control UI all embedded.
# ============================================================
SWIFTWARD_SERVER_IMAGE=ghcr.io/disciplinedware/ai-trading-agents/swiftward-server:latest
# For local dev with swiftward-server source, override with:
#   SWIFTWARD_SERVER_IMAGE=swiftward-server:local

# ============================================================
# Classifiers - HuggingFace token for prompt injection detection
# ============================================================
# The classifiers service runs Llama Prompt Guard 2 (gated model).
# 1. Accept the license at https://huggingface.co/meta-llama/Llama-Prompt-Guard-2-86M
# 2. Create a token at https://huggingface.co/settings/tokens
# Optional. Without this, prompt injection detection is disabled. Everything else works fine.
# CLASSIFIER_HF_TOKEN=

# ============================================================
# LLM backend - OpenAI (default) or local model via LM Studio / Ollama
# ============================================================

# Option A: OpenAI (default)
# Also used by Swiftward's LLM moderation (attention recovery policy).
# OPENAI_API_KEY=
LLM_MODERATION_ENDPOINT=https://api.openai.com/v1/chat/completions
LLM_MODERATION_MODEL=gpt-5-mini

# Option B: Custom upstream (OpenRouter, LM Studio, Ollama, etc.)
# These override where the LLM Gateway proxies requests.
# Default: official OpenAI/Anthropic APIs. No restart needed - just change .env and recreate.
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ============================================================
# PRISM API - market intelligence enrichment (fear/greed, technicals, signals)
# Sign up at https://prismapi.ai, redeem code LABLAB for free credits.
# Circuit breaker auto-disables on failures (429, 5xx) and probes to recover.
# ============================================================
# PRISM_API_KEY=
# TRADING__MARKET_DATA__PRISM__ENABLED=true

# ============================================================
# Telegram - bot token + chat ID (shared by all Telegram features)
# ============================================================
# Get a bot token from @BotFather.
# To get chat ID: message your bot, then curl https://api.telegram.org/bot<TOKEN>/getUpdates
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# Topic IDs for forum-style group chats (leave empty for regular chats).
# Each feature posts to its own topic thread:
# TELEGRAM_SWIFTWARD_TOPIC_ID=
# TELEGRAM_ALPHA_CLAUDE_TOPIC_ID=
# TELEGRAM_GAMMA_CLAUDE_TOPIC_ID=

# ============================================================
# Agents - each has unique ID + API key
# ============================================================

# --- Random agent (baseline) ---
AGENT_RANDOM_ID=agent-random
AGENT_RANDOM_API_KEY=sw_live_random
# AGENT_RANDOM_PRIVATE_KEY=0x...             # agent's own EOA key (make gen-wallets)
# AGENT_RANDOM_REGISTRATION_URI=ipfs://...   # IPFS CID of agent registration JSON
# AGENT_RANDOM_HACKATHON_AGENT_ID=           # agentId from: make register-agent-hackathon AGENT=RANDOM

# --- Swiftward Alpha (Claude agent with Swiftward policy) ---
AGENT_ALPHA_CLAUDE_ID=agent-alpha-claude
AGENT_ALPHA_CLAUDE_API_KEY=sw_live_swiftward_alpha
# AGENT_ALPHA_CLAUDE_PRIVATE_KEY=0x...
# AGENT_ALPHA_CLAUDE_REGISTRATION_URI=ipfs://...
# AGENT_ALPHA_CLAUDE_HACKATHON_AGENT_ID=

# --- Swiftward Midas (LIVE Kraken trading, real money) ---
AGENT_MIDAS_CLAUDE_ID=agent-midas-claude
AGENT_MIDAS_CLAUDE_API_KEY=sw_live_swiftward_midas
# AGENT_MIDAS_CLAUDE_PRIVATE_KEY=0x...
# AGENT_MIDAS_CLAUDE_REGISTRATION_URI=ipfs://...
# AGENT_MIDAS_CLAUDE_HACKATHON_AGENT_ID=
# TELEGRAM_MIDAS_CLAUDE_TOPIC_ID=

# --- Swiftward Gamma (Claude multi-subagent trader) ---
AGENT_GAMMA_CLAUDE_ID=agent-gamma-claude
AGENT_GAMMA_CLAUDE_API_KEY=sw_live_swiftward_gamma
# AGENT_GAMMA_CLAUDE_PRIVATE_KEY=0x...
# AGENT_GAMMA_CLAUDE_REGISTRATION_URI=ipfs://...
# AGENT_GAMMA_CLAUDE_HACKATHON_AGENT_ID=

# --- Swiftward Delta (Go LLM agent) ---
AGENT_DELTA_GO_ID=agent-delta-go
AGENT_DELTA_GO_API_KEY=sw_live_simple_llm_golang
AGENT_DELTA_GO_MODEL=gpt-5.4-mini
# AGENT_DELTA_GO_PRIVATE_KEY=0x...
# AGENT_DELTA_GO_WALLET_ADDR=0x...
# AGENT_DELTA_GO_REGISTRATION_URI=ipfs://...
# AGENT_DELTA_GO_STANDARD_AGENT_ID=

# --- Swiftward Epsilon (Rust LLM agent) ---
AGENT_EPSILON_RUST_ID=agent-epsilon-rust
AGENT_EPSILON_RUST_API_KEY=sw_live_simple_llm_rust
AGENT_EPSILON_RUST_MODEL=gpt-5.4-mini
# AGENT_EPSILON_RUST_PRIVATE_KEY=0x...
# AGENT_EPSILON_RUST_WALLET_ADDR=
# AGENT_EPSILON_RUST_REGISTRATION_URI=ipfs://...

# --- Python Deterministic LLM ---
AGENT_PYTHON_DETERMINISTIC_LLM_ID=agent-python-deterministic-llm
AGENT_PYTHON_DETERMINISTIC_LLM_API_KEY=sw_live_python_deterministic_llm
AGENT_PYTHON_DETERMINISTIC_LLM_INITIAL_BALANCE=10000
# AGENT_PYTHON_DETERMINISTIC_LLM_PRIVATE_KEY=0x...
# AGENT_PYTHON_DETERMINISTIC_LLM_WALLET_ADDR=0x...
# AGENT_PYTHON_DETERMINISTIC_LLM_ERC8004_AGENT_ID=
# AGENT_PYTHON_DETERMINISTIC_LLM_REGISTRATION_URI=ipfs://...

# --- Gamma Java (Fear & Greed Contrarian, Spring Boot) ---
AGENT_GAMMA_JAVA_ID=agent-gamma-java
AGENT_GAMMA_JAVA_API_KEY=sw_live_gamma_java
# AGENT_GAMMA_JAVA_TICK_INTERVAL_MS=900000   # 15 min default; override for faster ticks
# AGENT_GAMMA_JAVA_PRIVATE_KEY=0x...
# AGENT_GAMMA_JAVA_HACKATHON_AGENT_ID=

# ============================================================
# Exchange mode: kraken_paper (default), paper (Binance prices + fake fills),
#   sim (GBM random walk - offline only), kraken_real (needs API key)
# ============================================================
TRADING__EXCHANGE__MODE=kraken_paper
# Commission rate (side-dependent). Buy: fee in base, sell: fee in quote.
# Default: 0.001 (0.1%). Kraken default: 0.0026 (0.26%).
TRADING__EXCHANGE__COMMISSION_RATE=0.001
# Kraken CLI binary path (default: "kraken"). Only needed if not on PATH.
# TRADING__EXCHANGE__KRAKEN_BIN=kraken
# Kraken API credentials (kraken_real mode only). Not needed for paper trading.
# CLI reads these directly as KRAKEN_API_KEY / KRAKEN_API_SECRET (not koanf).
# KRAKEN_API_KEY=
# KRAKEN_API_SECRET=

# ============================================================
# Market Data source chain. Kraken for spot data, Bybit for futures (funding, OI).
# USD pairs are auto-mapped to USDT perps for futures queries.
# Override to simulated for fully offline testing.
# ============================================================
TRADING__MARKET_DATA__SOURCES=kraken,bybit

# ============================================================
# News - CryptoPanic API token
# ============================================================
# CRYPTOPANIC_TOKEN=

# ============================================================
# Trading Database (auto-created by postgres/init-databases.sh)
# ============================================================
# TRADING__DB__URL=postgres://trading:trading@postgres:5432/trading?sslmode=disable

# ============================================================
# Swiftward Policy Evaluation (enabled by default)
# ============================================================
# Policy engine evaluates every trade_intent before execution.
# Set to false to disable (all trades pass through).
# SWIFTWARD_ENABLED=false

# ============================================================
# Blockchain - ERC-8004 on Sepolia
# Setup: (1) make gen-wallets  (2) fund both wallets  (3) make solidity-deploy per agent
#
# Private keys are PLATFORM-level - Swiftward (gateway) signs on behalf of ALL agents.
# Each agent gets its own AgentWallet contract (WalletAddr), same guardian key.
# ============================================================
# CHAIN_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
CHAIN_ID=11155111

# Standard ERC-8004 contracts
ERC8004_IDENTITY_ADDR=0x8004A818BFB912233c491871b3d84c89A494BD9e
ERC8004_VALIDATION_ADDR=0x8004Cb1BF31DAf7788923b405b754f57acEB4272
ERC8004_REPUTATION_ADDR=0x8004B663056A597Dffe9eCcC1965A193B7388713

# Hackathon contracts (leaderboard, RiskRouter, judge bot read from these)
HACKATHON_IDENTITY_ADDR=0x97b07dDc405B0c28B17559aFFE63BdB3632d0ca3
# HACKATHON_VALIDATION_ADDR=0x92bF63E5C7Ac6980f237a7164Ab413BE226187F1  # disabled by organizers
HACKATHON_REPUTATION_ADDR=0x423a9904e39537a9997fbaF0f220d79D7d545763
HACKATHON_RISK_ROUTER_ADDR=0xd6A6952545FF6E6E6681c2d15C59f9EB8F40FdBC
HACKATHON_VAULT_ADDR=0x0E7CD8ef9743FEcf94f9103033a044caBD45fC90

# Hardcoded confidence for validation checkpoints (0-100).
# Set to 100 for max leaderboard score. Set to 0 to use agent's confidence.
HARDCODED_CONFIDENCE=100

# === VALIDATOR WALLET ===
# CHAIN_VALIDATOR_PRIVATE_KEY=0x...
# CHAIN_VALIDATOR_ADDR=0x...

# Fund addresses with Sepolia ETH:
# https://cloud.google.com/application/web3/faucet/ethereum/sepolia

# Tokens (Sepolia)
USDC_ADDR=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
WETH_ADDR=0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14

# ============================================================
# IPFS (Pinata) - for ERC-8004 agent registration metadata
# Sign up at https://app.pinata.cloud, create API key, copy JWT.
# ============================================================
# PINATA_JWT=eyJ...

# ============================================================
# Etherscan API (for contract verification)
# ============================================================
# ETHERSCAN_API_KEY=

# ============================================================
# Code Sandbox - workspace bind-mount into sandbox containers
# Required for code/execute to read files written by Files MCP.
# Set to absolute host path of the ./data/workspace directory.
# ============================================================
# HOST_WORKSPACE_PATH=/absolute/path/to/ai-trading-agents/data/workspace

# ============================================================
# Agents Arena (Ruby) - backtesting + strategy selection
# ============================================================
RAILS_MASTER_KEY=dc64157ce94f590a571964c299e4a41c
RAILS_SECRET_KEY_BASE=ad80d8610bdde8870814887a51a4877e980afc28ba1df8a5e8c073da6d7111924c0b3e1e6cfbaa9cb4eb2d9af3248298e7e7310a4a8982373d1e15157b14bfe8
RAILS_SWIFTWARD_API_KEY=sw_live_ruby_agent
RAILS_SWIFTWARD_AGENT_ID=agent-ruby-solid
# Analytic Sandbox for Ruby agent — shared data dir (must be absolute path on host).
# Defaults to <repo>/data/ruby-sandbox-data. Override only if needed.
# SANDBOX_DATA_PATH=/custom/absolute/path
# RUBY_SANDBOX_TOKEN=
