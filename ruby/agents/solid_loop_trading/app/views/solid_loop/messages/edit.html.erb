<div class="mx-auto max-w-3xl px-4 py-10 sm:px-6 lg:px-8">
  <div class="space-y-10 divide-y divide-gray-700">
    <div class="grid grid-cols-1 gap-x-8 gap-y-8 pt-10 md:grid-cols-3">
      <div class="px-4 sm:px-0">
        <h2 class="text-base font-semibold leading-7 text-gray-100">Edit Message</h2>
        <p class="mt-1 text-sm leading-6 text-gray-400">Modify the content of this message. Role: <%= @message.role.humanize %></p>
      </div>

      <%= form_with(model: [@agent_run, @message], class: "bg-gray-900 shadow-sm ring-1 ring-gray-700 sm:rounded-xl md:col-span-2") do |f| %>
        <div class="px-4 py-6 sm:p-8">
          <div class="grid max-w-2xl grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-6">
            <div class="col-span-full">
              <%= f.label :content, class: "block text-sm font-medium leading-6 text-gray-100" %>
              <div class="mt-2">
                <%= f.text_area :content, rows: 10, class: "block w-full rounded-md border-0 py-1.5 text-gray-100 bg-gray-800 shadow-sm ring-1 ring-inset ring-gray-600 placeholder:text-gray-500 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 font-mono" %>
              </div>
            </div>
          </div>
        </div>
        <div class="flex items-center justify-end gap-x-6 border-t border-gray-700 px-4 py-4 sm:px-8">
          <%= link_to "Cancel", agent_run_path(@agent_run), class: "text-sm font-semibold leading-6 text-gray-300" %>
          <%= f.submit "Save Changes", class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
        </div>
      <% end %>
    </div>
  </div>
</div>