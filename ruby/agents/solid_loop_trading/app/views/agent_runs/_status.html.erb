<div class="flex flex-col gap-2" id="<%= dom_id(conversation, :status) %>">

  <%# ── Session (current LLM loop) ─────────────────────────────── %>
  <div class="flex items-center gap-3">
    <span class="text-[10px] uppercase tracking-wide text-gray-500 font-bold w-20 shrink-0">Session</span>
    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
      <%= case conversation.loop&.status
          when 'running'   then 'bg-yellow-900/50 text-yellow-300 animate-pulse'
          when 'queued'    then 'bg-yellow-900/30 text-yellow-400'
          when 'paused'    then 'bg-gray-800 text-gray-300'
          when 'completed' then 'bg-blue-900/50 text-blue-300 border border-blue-700'
          when 'failed'    then 'bg-red-900/50 text-red-300 border border-red-700'
          else 'bg-gray-800 text-gray-300'
          end %>">
      <%= conversation.loop&.status&.humanize || "No session" %>
    </span>

    <% if conversation.loop&.running? %>
      <%= button_to "Pause", pause_agent_run_path(conversation), method: :post,
          class: "text-xs text-red-400 hover:text-red-300 font-medium" %>
    <% elsif conversation.loop&.init? || conversation.loop&.paused? || conversation.loop&.failed? %>
      <%= button_to "Resume", resume_agent_run_path(conversation), method: :post,
          class: "text-xs text-indigo-400 hover:text-indigo-300 font-medium" %>
    <% end %>
  </div>

<%# ── Orchestrator / Backtest status ── %>
  <div class="flex items-center gap-3">
    <span class="text-[10px] uppercase tracking-wide text-gray-500 font-bold w-20 shrink-0"><%= conversation.live? ? "Orchestrator" : "Backtest" %></span>
    <%
      orch_css, orch_title = case conversation.orchestrator_status
        when "initial" then [ "bg-gray-800 text-gray-400",         "Not started yet." ]
        when "running" then [ "bg-yellow-900/50 text-yellow-300",   conversation.live? ? "LLM session is active right now. Agent is analyzing the market and may submit orders." : "Backtest in progress — processing current turn." ]
        when "waiting" then [ "bg-emerald-900/50 text-emerald-300", conversation.live? ? "Session finished. Orchestrator will wake the agent on an alert or heartbeat timer." : "Backtest paused — waiting for next turn." ]
        when "stopped" then [ "bg-red-900/50 text-red-300",         conversation.live? ? "Orchestrator is stopped. Agent will NOT be woken up until you start it again." : "Backtest finished." ]
        else                 [ "bg-gray-800 text-gray-400",         conversation.orchestrator_status ]
        end
    %>
    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= orch_css %>" title="<%= orch_title %>">
      <%= conversation.orchestrator_status.humanize %>
    </span>

    <% if conversation.orchestrator_stopped? %>
      <%= button_to "Start", resume_agent_agent_run_path(conversation), method: :post,
          class: "text-xs text-emerald-400 hover:text-emerald-300 font-medium" %>
    <% else %>
      <%= button_to "Stop", stop_agent_agent_run_path(conversation), method: :post,
          data: { confirm: "Stop? Agent won't be woken up until you start it again." },
          class: "text-xs text-red-400 hover:text-red-300 font-medium" %>
    <% end %>
  </div>

  <% if conversation.loop&.error_message.present? %>
    <div class="text-xs text-red-400 font-mono bg-red-950/50 px-2 py-1 rounded border border-red-800 overflow-x-auto"
         title="<%= conversation.loop.error_message %>">
      <%= conversation.loop.error_message %>
    </div>
  <% end %>

</div>
