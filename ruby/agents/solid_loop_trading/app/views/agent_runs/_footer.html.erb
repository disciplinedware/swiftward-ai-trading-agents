<div class="bg-gray-900 border-t border-gray-700 p-4 shadow-[0_-1px_3px_0_rgba(0,0,0,0.3)]">
  <div class="max-w-7xl mx-auto">
    <%= form_with(model: [@agent_run, SolidLoop::Message.new], url: agent_run_messages_path(@agent_run), html: { id: "message_form" }, class: "flex gap-4") do |f| %>
      <%= f.hidden_field :role, value: "user" %>
      <div class="flex-1">
        <%= f.text_area :content, rows: 1, placeholder: "Type your message...", class: "block w-full rounded-md border-0 py-1.5 text-gray-100 bg-gray-800 shadow-sm ring-1 ring-inset ring-gray-600 placeholder:text-gray-500 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6", data: { action: "keydown.enter->scroll#submit" } %>
      </div>
      <%= f.submit "Send", class: "inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
    <% end %>
  </div>
</div>