<header class="bg-gray-900">
    <div class="max-w-7xl mx-auto py-4 px-4 sm:px-6 lg:px-8 flex justify-between items-center">
      <div class="flex items-center gap-3">
        <div>
          <h2 class="text-lg font-semibold text-gray-100 flex items-center gap-2">
            <%= @agent_run.title.presence || @agent_run.loop&.title.presence || "Run" %>
          </h2>
          <div class="flex flex-col gap-1 mt-1">
            <p class="text-xs text-gray-400 font-medium">Model: <span class="text-indigo-400"><%= @agent_run.agent_model&.name %></span></p>
            <% if @agent_run.trading_scenario || @agent_run.agent_batch %>
              <p class="text-xs text-gray-400 font-medium">
                <% if @agent_run.trading_scenario %>
                  Scenario: <%= link_to @agent_run.trading_scenario.name, @agent_run.trading_scenario, class: "text-indigo-400 hover:text-indigo-300 underline" %>
                <% end %>
                <% if @agent_run.trading_scenario && @agent_run.agent_batch %>
                   in
                <% end %>
                <% if @agent_run.agent_batch %>
                  Batch: <%= link_to "##{@agent_run.agent_batch.id} (#{@agent_run.agent_batch.prefix.presence || @agent_run.agent_batch.id})", agent_batch_path(@agent_run.agent_batch), class: "text-indigo-400 hover:text-indigo-300 underline" %>
                <% end %>
              </p>
            <% end %>
            <% if (agent_class = @agent_run.loop&.agent_class_name).present? %>
              <p class="text-xs text-gray-400 font-medium">Agent: <span class="<%= agent_class == 'SwiftwardTradingAgent' ? 'text-emerald-400' : 'text-indigo-400' %> font-mono"><%= agent_class %></span></p>
            <% end %>
            <% if @agent_run.filename.present? %>
              <p class="text-xs text-gray-400 font-medium italic">File: <span class="text-indigo-400 font-mono text-[10px]"><%= @agent_run.filename %></span></p>
            <% end %>
            <% mcp_sessions = @agent_run.loop&.mcp_sessions %>
            <% swiftward_agent_id = @agent_run.agent_id %>
            <% if mcp_sessions&.any? || swiftward_agent_id.present? %>
              <div class="flex items-center gap-1.5 flex-wrap">
                <span class="text-[10px] text-gray-500 font-bold uppercase tracking-wide">MCP</span>
                <% if mcp_sessions&.any? %>
                  <div class="inline-flex items-center rounded border border-gray-700 overflow-hidden shadow-sm">
                    <% mcp_sessions.each_with_index do |session, i| %>
                      <%= link_to mcp_agent_run_path(@agent_run, session_id: session.session_id), title: session.session_id,
                          class: "#{i > 0 ? 'border-l border-gray-700' : ''} inline-flex items-center gap-1 px-2 py-0.5 text-[10px] font-mono font-semibold bg-gray-800 hover:bg-indigo-900/50 text-indigo-400 hover:text-indigo-300 transition-colors" do %>
                        <span class="w-1.5 h-1.5 rounded-full bg-green-400 shrink-0"></span>
                        <%= session.mcp_name %>
                      <% end %>
                    <% end %>
                  </div>
                <% end %>
                <% if swiftward_agent_id.present? %>
                  <%= link_to trading_session_path(swiftward_agent_id),
                      class: "inline-flex items-center gap-1 px-2 py-0.5 text-[10px] font-mono font-semibold rounded border border-emerald-800 bg-emerald-900/30 text-emerald-400 hover:bg-emerald-900/50 hover:text-emerald-300 transition-colors shadow-sm" do %>
                    <svg class="w-2.5 h-2.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                    portfolio
                  <% end %>
                <% elsif mcp_sessions&.any? %>
                  <% trading_session = mcp_sessions.find { |s| s.mcp_name == "trading" } %>
                  <% if trading_session && TradingSession.exists?(uuid: trading_session.session_id) %>
                    <%= link_to trading_session_path(trading_session.session_id),
                        class: "inline-flex items-center gap-1 px-2 py-0.5 text-[10px] font-mono font-semibold rounded border border-emerald-800 bg-emerald-900/30 text-emerald-400 hover:bg-emerald-900/50 hover:text-emerald-300 transition-colors shadow-sm" do %>
                      <svg class="w-2.5 h-2.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                      portfolio
                    <% end %>
                  <% end %>
                <% end %>
              </div>
            <% end %>
            <% if @agent_run.loop %>
              <p class="text-xs text-gray-400 font-medium">
                Events: <%= link_to "View All", main_app.agent_events_path(loop_id: @agent_run.loop.id), class: "text-indigo-400 hover:text-indigo-300 underline font-mono", data: { turbo: false } %>
                | Tools: <%= link_to "View All", tools_agent_run_path(@agent_run), class: "text-indigo-400 hover:text-indigo-300 underline font-mono" %>
              </p>
            <% end %>
          </div>
        </div>
      </div>

      <div class="flex items-center space-x-4">
        <div id="agent_run_status">
          <%= render "agent_runs/status", conversation: @agent_run %>
        </div>
        <div class="h-6 w-px bg-gray-700"></div>
        <%= link_to download_agent_run_path(@agent_run), title: "Download HTML", class: "text-gray-500 hover:text-gray-300", data: { turbo: false } do %>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
        <% end %>
        <%= link_to edit_agent_run_path(@agent_run), title: "Settings", class: "text-gray-500 hover:text-gray-300" do %>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37a1.724 1.724 0 002.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        <% end %>
      </div>
    </div>
  </header>