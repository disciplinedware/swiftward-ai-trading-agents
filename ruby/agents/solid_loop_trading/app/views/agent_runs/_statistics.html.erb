<%
  l = @agent_run.loop
  if l
    counts = l.messages.group(:role).count
    tool_counts = l.tool_calls.group(:is_success).count
  else
    counts = {}
    tool_counts = {}
  end
%>

<div class="bg-gray-800/50 border-b border-gray-700 px-4 py-2 text-[10px] text-gray-400 font-mono">
  <div class="max-w-7xl mx-auto flex flex-wrap gap-x-6 gap-y-1 items-center">
    <div class="flex items-center gap-1">
      <svg style="width: 2em; height: 2em;" class="w-3 h-3 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" /></svg>
      <span>Msgs:
        In: <strong class="text-gray-100"><%= (counts['user'] || 0) + (counts['system'] || 0) %></strong> |
        Tools: <strong class="text-gray-100" title="Total calls"><%= counts['tool'] || 0 %></strong>
        <span class="text-[9px] text-gray-500 ml-0.5">(<span class="text-green-400 font-bold"><%= tool_counts[true] || 0 %></span>/<span class="text-red-400 font-bold"><%= tool_counts[false] || 0 %></span>)</span> |
        Out: <strong class="text-gray-100"><%= counts['assistant'] || 0 %></strong>
      </span>
    </div>

    <div class="flex items-center gap-1">
      <svg style="width: 2em; height: 2em;" class="w-3 h-3 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
      <span>Tokens:
        In: <strong class="text-gray-100"><%= number_with_delimiter(l&.tokens_prompt || 0) %></strong> |
        Out: <strong class="text-gray-100"><%= number_with_delimiter(l&.tokens_completion || 0) %></strong><% if l&.tokens_prompt_cached&.to_i&.positive? %> |
        Cached: <strong class="text-gray-100"><%= number_with_delimiter(l.tokens_prompt_cached) %></strong><% end %> |
        Cost: <strong class="text-green-400">$<%= number_with_precision(l&.cost || 0, precision: 5) %></strong>
      </span>
    </div>

    <div class="flex items-center gap-1">
      <svg style="width: 2em; height: 2em;" class="w-3 h-3 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <span>Duration:
        LLM: <strong class="text-gray-100"><%= l && l.duration_generation > 300 ? distance_of_time_in_words(l.duration_generation) : "#{number_with_precision(l&.duration_generation || 0, precision: 2)}s" %></strong> |
        Tools: <strong class="text-gray-100"><%= l && l.duration_tools > 300 ? distance_of_time_in_words(l.duration_tools) : "#{number_with_precision(l&.duration_tools || 0, precision: 2)}s" %></strong>
      </span>
    </div>

    <div class="flex items-center gap-1 ml-auto">
      <span class="text-gray-500">TPS:</span>
      <span class="bg-indigo-950/50 text-indigo-300 px-1.5 py-0.5 rounded font-bold">
        <%= l && l.duration_generation > 0 ? number_with_precision(l.tokens_completion.to_f / l.duration_generation, precision: 2) : "0.00" %>
      </span>
    </div>
  </div>
</div>