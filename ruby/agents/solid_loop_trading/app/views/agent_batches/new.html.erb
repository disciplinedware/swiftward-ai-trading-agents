<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="sm:flex sm:items-center">
      <div class="sm:flex-auto">
        <h1 class="text-3xl font-bold tracking-tight text-gray-100">New Agent Batch</h1>
        <p class="mt-2 text-sm text-gray-400">
Batch will be created in an <strong>INIT</strong> state.
            Please check that all scenarios are correct, buy/start your server/model, and wait for it to warm up.
            Once ready, you can <strong>START</strong> the batch from the list.
        </p>
      </div>
    </div>

    <%= form_with(model: @agent_batch, class: "mt-8 space-y-8 divide-y divide-gray-700", data: { controller: "batch-mode" }) do |form| %>
      <% if @agent_batch.errors.any? %>
        <div class="rounded-md bg-red-950/50 p-4 mb-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-300">
                <%= pluralize(@agent_batch.errors.count, "error") %> prohibited this batch from being saved:
              </h3>
              <div class="mt-2 text-sm text-red-400">
                <ul role="list" class="list-disc pl-5 space-y-1">
                  <% @agent_batch.errors.each do |error| %>
                    <li><%= error.full_message %></li>
                  <% end %>
                </ul>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <div class="space-y-8 divide-y divide-gray-700">
        <div class="mt-6 grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6 grid-rows-[auto_auto_auto_auto]">
            <div class="sm:col-span-3">
              <%= form.label :agent_model_id, "Agent Model", class: "block text-sm font-medium leading-6 text-gray-100" %>
              <div class="mt-2">
                <%= form.collection_select :agent_model_id, AgentModel.all, :id, :name, { prompt: "Select a model..." }, required: true, class: "block w-full rounded-md border-0 py-1.5 text-gray-100 bg-gray-800 shadow-sm ring-1 ring-inset ring-gray-600 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" %>
              </div>
            </div>

            <div class="sm:col-span-3">
               <%= form.label :concurrency, class: "block text-sm font-medium leading-6 text-gray-100" %>
               <div class="mt-2">
                 <%= form.number_field :concurrency, value: 1, min: 1, class: "block w-full rounded-md border-0 py-1.5 text-gray-100 bg-gray-800 shadow-sm ring-1 ring-inset ring-gray-600 placeholder:text-gray-500 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" %>
               </div>
            </div>

            <div class="sm:col-span-3">
               <%= form.label :attempts, "Attempts per Scenario", class: "block text-sm font-medium leading-6 text-gray-100" %>
               <div class="mt-2">
                 <%= form.number_field :attempts, value: 1, min: 1, class: "block w-full rounded-md border-0 py-1.5 text-gray-100 bg-gray-800 shadow-sm ring-1 ring-inset ring-gray-600 placeholder:text-gray-500 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" %>
               </div>
               <p class="mt-2 text-sm text-gray-500">If attempts = 3, this will create <%= @agent_batch.attempts || 1 %> runs for each selected scenario.</p>
            </div>

            <div class="sm:col-span-3">
               <%= form.label :prefix, class: "block text-sm font-medium leading-6 text-gray-100" %>
               <div class="mt-2">
                 <%= form.text_field :prefix, class: "block w-full rounded-md border-0 py-1.5 text-gray-100 bg-gray-800 shadow-sm ring-1 ring-inset ring-gray-600 placeholder:text-gray-500 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" %>
               </div>
               <p class="mt-2 text-sm text-gray-500">Appended to run title: [Prefix] TaskName #1</p>
            </div>

            <div class="sm:col-span-6">
              <label class="block text-sm font-medium leading-6 text-gray-100 mb-3">Agent Mode</label>
              <div class="flex gap-4" data-batch-mode-target="radios">
                <label class="flex items-center gap-3 cursor-pointer rounded-lg border border-gray-700 px-4 py-3 flex-1 has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-950/30">
                  <%= form.radio_button :agent_mode, "backtesting", class: "h-4 w-4 text-indigo-600 border-gray-600 focus:ring-indigo-600", id: "mode_backtesting", data: { action: "batch-mode#toggle", batch_mode_target: "backtestingRadio" } %>
                  <div>
                    <span class="block text-sm font-semibold text-gray-100">Backtesting</span>
                    <span class="block text-xs text-gray-500">Simulation with historical data and virtual time</span>
                  </div>
                </label>
                <label class="flex items-center gap-3 cursor-pointer rounded-lg border border-gray-700 px-4 py-3 flex-1 has-[:checked]:border-emerald-500 has-[:checked]:bg-emerald-950/30">
                  <%= form.radio_button :agent_mode, "swiftward", class: "h-4 w-4 text-emerald-600 border-gray-600 focus:ring-emerald-600", id: "mode_swiftward", data: { action: "batch-mode#toggle", batch_mode_target: "swiftwardRadio" } %>
                  <div>
                    <span class="block text-sm font-semibold text-gray-100">Swiftward (Live)</span>
                    <span class="block text-xs text-gray-500">Routes through Swiftward gateway with policy guardrails</span>
                  </div>
                </label>
              </div>
            </div>

            <div data-batch-mode-target="backtestingFields" class="sm:col-span-6 bg-indigo-950/30 p-4 rounded-lg border border-indigo-800">
              <h3 class="text-sm font-semibold text-indigo-300 mb-4 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
                Simulation Time Overrides (Optional)
              </h3>
              <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
                <div class="sm:col-span-2">
                  <%= form.label :start_at, "Start Date (UTC)", class: "block text-sm font-medium leading-6 text-gray-100" %>
                  <div class="mt-2">
                    <%= form.datetime_field :start_at, class: "block w-full rounded-md border-0 py-1.5 text-gray-100 bg-gray-800 shadow-sm ring-1 ring-inset ring-gray-600 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" %>
                  </div>
                </div>

                <div class="sm:col-span-2">
                  <%= form.label :end_at, "End Date (UTC)", class: "block text-sm font-medium leading-6 text-gray-100" %>
                  <div class="mt-2">
                    <%= form.datetime_field :end_at, class: "block w-full rounded-md border-0 py-1.5 text-gray-100 bg-gray-800 shadow-sm ring-1 ring-inset ring-gray-600 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" %>
                  </div>
                </div>

                <div class="sm:col-span-2">
                  <%= form.label :step_interval, "Step Interval (sec)", class: "block text-sm font-medium leading-6 text-gray-100" %>
                  <div class="mt-2">
                    <%= form.number_field :step_interval, placeholder: "e.g. 86400 for 1 day", class: "block w-full rounded-md border-0 py-1.5 text-gray-100 bg-gray-800 shadow-sm ring-1 ring-inset ring-gray-600 placeholder:text-gray-500 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" %>
                  </div>
                </div>
              </div>
              <p class="mt-3 text-xs text-indigo-400 italic">
                If provided, these values will override the default settings of each selected scenario for this batch run.
              </p>
            </div>

            <div data-batch-mode-target="swiftwardFields" class="sm:col-span-6 bg-emerald-950/30 p-4 rounded-lg border border-emerald-800 hidden">
              <h3 class="text-sm font-semibold text-emerald-300 mb-4 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                </svg>
                Live Trading Settings
              </h3>
              <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
                <div class="sm:col-span-2">
                  <%= form.label :wakeup_interval_minutes, "Wakeup Interval (min)", class: "block text-sm font-medium leading-6 text-gray-100" %>
                  <div class="mt-2">
                    <%= form.number_field :wakeup_interval_minutes, min: 1, class: "block w-full rounded-md border-0 py-1.5 text-gray-100 bg-gray-800 shadow-sm ring-1 ring-inset ring-gray-600 placeholder:text-gray-500 focus:ring-2 focus:ring-inset focus:ring-emerald-600 sm:text-sm sm:leading-6" %>
                  </div>
                  <p class="mt-2 text-xs text-emerald-400 italic">How often the orchestrator will force-wake the agent to re-evaluate market conditions, even when no alerts have triggered. Default: 15 min.</p>
                </div>
              </div>
            </div>

            <div class="sm:col-span-6">
                <label class="block text-sm font-medium leading-6 text-gray-100">Selected Scenarios</label>
                <div class="mt-2 border border-gray-700 rounded-md p-4 max-h-60 overflow-y-auto bg-gray-800">
                    <% if params[:agent_batch] && params[:agent_batch][:trading_scenario_ids] %>
                        <% selected_ids = params[:agent_batch][:trading_scenario_ids].map(&:to_i) %>
                        <% @trading_scenarios.each do |task| %>
                            <% if selected_ids.include?(task.id) %>
                                <div class="flex items-center">
                                    <input type="hidden" name="agent_batch[trading_scenario_ids][]" value="<%= task.id %>">
                                    <span class="text-sm text-gray-100"><%= task.name %></span>
                                </div>
                            <% end %>
                        <% end %>
                        <% if selected_ids.empty? %>
                             <p class="text-sm text-gray-500 italic">No scenarios selected.</p>
                        <% end %>
                    <% else %>
                        <p class="text-sm text-gray-500 italic">No scenarios selected via the Scenarios page.</p>
                    <% end %>
                </div>
            </div>
        </div>
      </div>

      <div class="pt-5">
        <div class="flex justify-end gap-x-3">
          <%= link_to "Cancel", trading_scenarios_path, class: "rounded-md bg-gray-800 px-3 py-2 text-sm font-semibold text-gray-100 shadow-sm ring-1 ring-inset ring-gray-600 hover:bg-gray-700" %>
          <%= form.submit "Create Batch", class: "inline-flex justify-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
        </div>
      </div>
    <% end %>
  </div>