<% batch = local_assigns[:batch] || @agent_batch %>
<% if batch.warm_up_status.in?(%w[not_started] + [nil]) && batch.init? %>
<%= tag.div id: dom_id(batch, :onboarding_alert) do %>
  <div class="mb-6 flex items-start gap-3 rounded-lg border border-amber-700/50 bg-amber-950/40 px-4 py-3">
    <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <div class="flex-1">
      <p class="text-sm text-amber-200">It is recommended to <strong>warm up</strong> the model to verify it works and preload weights before starting runs.</p>
      <p class="mt-1 text-xs text-amber-400/70">Warm-up sends a test request to the LLM provider and confirms connectivity.</p>
    </div>
    <div class="flex-shrink-0">
      <%= button_to "Warm Up Model", warm_up_agent_batch_path(batch), method: :post, class: "rounded-md bg-amber-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-amber-500 transition-colors" %>
    </div>
  </div>
<% end %>
<% elsif batch.warm_up_pending? || batch.warm_up_executing? %>
<%= tag.div id: dom_id(batch, :onboarding_alert) do %>
  <div class="mb-6 flex items-center gap-3 rounded-lg border border-blue-700/50 bg-blue-950/40 px-4 py-3">
    <svg class="h-5 w-5 flex-shrink-0 animate-spin text-blue-400" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
    </svg>
    <p class="text-sm text-blue-200"><%= batch.warm_up_executing? ? "Model warm-up is running..." : "Model warm-up is pending..." %></p>
  </div>
<% end %>
<% end %>