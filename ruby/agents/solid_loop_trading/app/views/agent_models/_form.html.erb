<%= form_with(model: agent_model, class: "space-y-8 divide-y divide-gray-700") do |form| %>
  <div class="space-y-8 divide-y divide-gray-700">
    <div class="pt-8">
      <div>
        <h3 class="text-base font-semibold leading-6 text-gray-100">General Information</h3>
        <p class="mt-1 text-sm text-gray-400">Basic configuration for the LLM model.</p>
      </div>

      <% if agent_model.errors.any? %>
        <div id="error_explanation" class="bg-red-900/50 p-4 rounded-md border border-red-700 mt-6">
          <h2 class="text-sm font-medium text-red-300"><%= pluralize(agent_model.errors.count, "error") %> prohibited this model from being saved:</h2>
          <ul class="mt-2 text-sm text-red-300 list-disc list-inside">
            <% agent_model.errors.full_messages.each do |error| %>
              <li><%= error %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mt-6 grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
        <div class="col-span-full">
          <%= form.label :agent_model_provider_id, "Provider", class: "block text-sm font-medium leading-6 text-gray-100" %>
          <div class="mt-2 flex gap-2">
            <%= form.collection_select :agent_model_provider_id, AgentModelProvider.order(:name), :id, :name, { prompt: "Select a provider" }, class: "block w-full rounded-md border-0 bg-gray-800 py-1.5 text-gray-100 shadow-sm ring-1 ring-inset ring-gray-600 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" %>
            <%= link_to "Manage", agent_model_providers_path, class: "inline-flex items-center rounded-md bg-gray-800 px-3 py-2 text-sm font-semibold text-gray-100 shadow-sm ring-1 ring-inset ring-gray-600 hover:bg-gray-800" %>
          </div>
        </div>

        <div class="col-span-full">
          <%= form.label :llm_model_name, "LLM Model ID", class: "block text-sm font-medium leading-6 text-gray-100" %>
          <div class="mt-2">
            <%= form.text_field :llm_model_name, placeholder: "e.g. gpt-4 or llama2", class: "block w-full rounded-md border-0 bg-gray-800 py-1.5 text-gray-100 shadow-sm ring-1 ring-inset ring-gray-600 placeholder:text-gray-500 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" %>
          </div>
        </div>

        <div class="col-span-full">
          <%= form.label :name, "Title (Optional)", class: "block text-sm font-medium leading-6 text-gray-100" %>
          <div class="mt-2">
            <%= form.text_field :name, placeholder: "Defaults to 'Provider : Model'", class: "block w-full rounded-md border-0 bg-gray-800 py-1.5 text-gray-100 shadow-sm ring-1 ring-inset ring-gray-600 placeholder:text-gray-500 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" %>
          </div>
        </div>

        <div class="col-span-full">
          <%= form.label :description, class: "block text-sm font-medium leading-6 text-gray-100" %>
          <div class="mt-2">
            <%= form.text_area :description, rows: 3, class: "block w-full rounded-md border-0 bg-gray-800 py-1.5 text-gray-100 shadow-sm ring-1 ring-inset ring-gray-600 placeholder:text-gray-500 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" %>
          </div>
          <p class="mt-3 text-sm leading-6 text-gray-400">Brief description of this model setup for future reference.</p>
        </div>
      </div>
    </div>

    <div class="pt-8">
      <div>
        <h3 class="text-base font-semibold leading-6 text-gray-100">Pricing (optional)</h3>
        <p class="mt-1 text-sm text-gray-400">Cost per 1M tokens in USD. Used to calculate cost when the provider does not return it. Leave at 0 to skip.</p>
      </div>
      <div class="mt-6 grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-3">
        <div>
          <%= form.label :price_per_input_token, "Input ($/1M tokens)", class: "block text-sm font-medium leading-6 text-gray-100" %>
          <div class="mt-2">
            <%= form.text_field :price_per_input_token, placeholder: "e.g. 1.0", class: "block w-full rounded-md border-0 bg-gray-800 py-1.5 text-gray-100 shadow-sm ring-1 ring-inset ring-gray-600 placeholder:text-gray-500 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" %>
          </div>
        </div>
        <div>
          <%= form.label :price_per_output_token, "Output ($/1M tokens)", class: "block text-sm font-medium leading-6 text-gray-100" %>
          <div class="mt-2">
            <%= form.text_field :price_per_output_token, placeholder: "e.g. 3.0", class: "block w-full rounded-md border-0 bg-gray-800 py-1.5 text-gray-100 shadow-sm ring-1 ring-inset ring-gray-600 placeholder:text-gray-500 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" %>
          </div>
        </div>
        <div>
          <%= form.label :price_per_cached_token, "Cached ($/1M tokens)", class: "block text-sm font-medium leading-6 text-gray-100" %>
          <div class="mt-2">
            <%= form.text_field :price_per_cached_token, placeholder: "e.g. 0.2", class: "block w-full rounded-md border-0 bg-gray-800 py-1.5 text-gray-100 shadow-sm ring-1 ring-inset ring-gray-600 placeholder:text-gray-500 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" %>
          </div>
        </div>
      </div>
    </div>

    <div class="pt-8">
      <div>
        <h3 class="text-base font-semibold leading-6 text-gray-100">Capabilities</h3>
        <p class="mt-1 text-sm text-gray-400">Select which tools this agent can use.</p>
      </div>
      <div class="mt-6">
        <fieldset>
          <legend class="sr-only">Tools</legend>
          <div class="grid grid-cols-1 gap-y-4 sm:grid-cols-2 sm:gap-x-6 lg:grid-cols-3">
            <% if @available_tools.present? %>
              <% @available_tools.each do |tool_name, tool_class_name| %>
                <div class="relative flex items-start">
                  <div class="flex h-6 items-center">
                    <%= check_box_tag "agent_model[tools][]", tool_class_name, agent_model.tools.include?(tool_class_name), id: "tool_#{tool_class_name}", class: "h-4 w-4 rounded border-gray-600 text-indigo-600 focus:ring-indigo-600" %>
                  </div>
                  <div class="ml-3 text-sm leading-6">
                    <%= label_tag "tool_#{tool_class_name}", tool_name, class: "font-medium text-gray-100" %>
                  </div>
                </div>
              <% end %>
            <% else %>
              <div class="col-span-full">
                <p class="text-sm text-gray-400 italic">No tools discovered. Run `rake mcp:generate_tools` or check app/tools.</p>
              </div>
            <% end %>
          </div>
        </fieldset>
      </div>
    </div>
  </div>

  <div class="pt-5">
    <div class="flex justify-end gap-x-3">
      <%= link_to "Cancel", agent_models_path, class: "rounded-md bg-gray-800 px-3 py-2 text-sm font-semibold text-gray-100 shadow-sm ring-1 ring-inset ring-gray-600 hover:bg-gray-800" %>
      <%= form.submit class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
    </div>
  </div>
<% end %>