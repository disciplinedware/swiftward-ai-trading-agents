<%= form_with(model: agent_model_provider, class: "space-y-6") do |form| %>
  <% if agent_model_provider.errors.any? %>
    <div id="error_explanation" class="bg-red-900/50 p-4 rounded-md border border-red-700 mb-6">
      <h2 class="text-sm font-medium text-red-300"><%= pluralize(agent_model_provider.errors.count, "error") %> prohibited this provider from being saved:</h2>
      <ul class="mt-2 text-sm text-red-300 list-disc list-inside">
        <% agent_model_provider.errors.full_messages.each do |error| %>
          <li><%= error %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-gray-300" %>
    <%= form.text_field :name, class: "mt-1 block w-full rounded-md bg-gray-800 border-gray-600 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm text-gray-100", placeholder: "e.g., OpenAI, OpenRouter, Anthropic" %>
  </div>

  <div>
    <%= form.label :base_url, class: "block text-sm font-medium text-gray-300" %>
    <p class="mt-1 text-xs text-gray-500 mb-1">Base URL only — do not include /v1, it will be appended automatically.</p>
    <%= form.text_field :base_url, class: "block w-full rounded-md bg-gray-800 border-gray-600 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm font-mono text-gray-100", placeholder: "https://api.openai.com" %>
  </div>

  <div>
    <%= form.label :api_key, class: "block text-sm font-medium text-gray-300" %>
    <%= form.password_field :api_key, value: agent_model_provider.api_key, class: "mt-1 block w-full rounded-md bg-gray-800 border-gray-600 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm font-mono text-gray-100", placeholder: "sk-..." %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-300" %>
    <%= form.text_area :description, rows: 3, class: "mt-1 block w-full rounded-md bg-gray-800 border-gray-600 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm text-gray-100" %>
  </div>

  <div class="flex items-center justify-end space-x-3">
    <%= link_to "Cancel", agent_model_providers_path, class: "text-sm font-medium text-gray-300 hover:text-gray-400" %>
    <%= form.submit class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
  </div>
<% end %>