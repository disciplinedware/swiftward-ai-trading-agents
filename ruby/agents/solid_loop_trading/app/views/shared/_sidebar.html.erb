<div class="hidden md:flex md:flex-shrink-0">
  <div class="flex flex-col w-64">
    <div class="flex flex-col h-0 flex-1 bg-gray-950 border-r border-gray-800">
      <div class="flex-1 flex flex-col pt-5 pb-4 overflow-y-auto">
        <div class="flex items-center flex-shrink-0 px-4">
          <h1 class="text-gray-100 text-xl font-bold">Solid Loop Trading</h1>
        </div>
        <nav class="mt-5 flex-1 px-2 space-y-1">
          <%= link_to agent_runs_path, class: "#{request.path == agent_runs_path ? 'bg-gray-800' : 'hover:bg-gray-800'} text-gray-300 group flex items-center px-2 py-2 text-sm font-medium rounded-md" do %>
            <svg class="text-gray-400 mr-3 flex-shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
            </svg>
            All Runs
          <% end %>

<%= link_to agent_model_providers_path, class: "#{request.path.start_with?(agent_model_providers_path) ? 'bg-gray-800' : 'hover:bg-gray-800'} text-gray-300 group flex items-center px-2 py-2 text-sm font-medium rounded-md" do %>
            <svg class="text-gray-400 mr-3 flex-shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            Model Providers
          <% end %>

          <%= link_to agent_models_path, class: "#{request.path.start_with?(agent_models_path) ? 'bg-gray-800' : 'hover:bg-gray-800'} text-gray-300 group flex items-center px-2 py-2 text-sm font-medium rounded-md" do %>
            <svg class="text-gray-400 mr-3 flex-shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
            Agent Models
          <% end %>

          <%= link_to trading_scenarios_path, class: "#{request.path.start_with?(trading_scenarios_path) ? 'bg-gray-800' : 'hover:bg-gray-800'} text-gray-300 group flex items-center px-2 py-2 text-sm font-medium rounded-md" do %>
            <svg class="text-gray-400 mr-3 flex-shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
            Scenarios
          <% end %>

          <%= link_to agent_batches_path, class: "#{request.path.start_with?(agent_batches_path) ? 'bg-gray-800' : 'hover:bg-gray-800'} text-gray-300 group flex items-center px-2 py-2 text-sm font-medium rounded-md" do %>
            <svg class="text-gray-400 mr-3 flex-shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Batches
          <% end %>

          <%= link_to trading_sessions_path, class: "#{request.path.start_with?(trading_sessions_path) ? 'bg-gray-800' : 'hover:bg-gray-800'} text-gray-300 group flex items-center px-2 py-2 text-sm font-medium rounded-md" do %>
            <svg class="text-gray-400 mr-3 flex-shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Tradings
          <% end %>

          <div class="my-3 border-t border-gray-800"></div>

          <%= link_to dashboard_backtesting_data_path, class: "#{request.path.start_with?(dashboard_backtesting_data_path) ? 'bg-gray-800' : 'hover:bg-gray-800'} text-gray-300 group flex items-center px-2 py-2 text-sm font-medium rounded-md" do %>
            <svg class="text-gray-400 mr-3 flex-shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
            </svg>
            Backtesting Data
          <% end %>
        </nav>
      </div>
    </div>
  </div>
</div>
