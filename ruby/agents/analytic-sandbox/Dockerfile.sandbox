# Dockerfile for analytic-sandbox
FROM ubuntu:24.04

# Prevent interactive prompts
ENV DEBIAN_FRONTEND=noninteractive

# Update and install dependencies
RUN apt-get update && apt-get install -y \
    ruby-full \
    python3 \
    python3-pip \
    golang-go \
    unzip \
    file \
    xxd \
    bsdmainutils \
    jq \
    tree \
    strace \
    ripgrep \
    fd-find \
    shellcheck \
    bc \
    sqlite3 \
    zip \
    p7zip-full \
    procps \
    pandoc \
    poppler-utils \
    dos2unix \
    imagemagick \
    ffmpeg \
    parallel \
    datamash \
    pv \
    zstd \
    xlsx2csv \
    python3-pandas \
    python3-numpy \
    python3-openpyxl \
    python3-bs4 \
    python3-lxml \
    ruby-nokogiri \
    wget \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Polars via pip (not in Ubuntu 24.04 apt)
RUN pip3 install --no-cache-dir --break-system-packages polars

# Install DuckDB
RUN ARCH=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/') && \
    wget https://github.com/duckdb/duckdb/releases/download/v1.1.3/duckdb_cli-linux-${ARCH}.zip && \
    unzip duckdb_cli-linux-${ARCH}.zip -d /usr/local/bin && \
    rm duckdb_cli-linux-${ARCH}.zip

# Install XSV
RUN ARCH=$(uname -m) && \
    wget https://github.com/BurntSushi/xsv/releases/download/0.13.0/xsv-0.13.0-${ARCH}-unknown-linux-musl.tar.gz && \
    tar -xzf xsv-0.13.0-${ARCH}-unknown-linux-musl.tar.gz -C /usr/local/bin && \
    rm xsv-0.13.0-${ARCH}-unknown-linux-musl.tar.gz

# Set up workspace
# Set up workspace
RUN id -u ubuntu >/dev/null 2>&1 || useradd -m -u 1000 ubuntu && \
    mkdir -p /app && \
    chown -R ubuntu:ubuntu /app /home/ubuntu

# Data Engineering Environment
ENV GOCACHE=/tmp/go-build
ENV GOPATH=/tmp/go
ENV HOME=/home/ubuntu
ENV PATH=$PATH:/usr/local/go/bin

USER ubuntu
WORKDIR /app

# Default command (overridden by MCP server)
CMD ["tail", "-f", "/dev/null"]
