# AI Trading Agents Platform - Trading Server + Dashboard UI
# Combined build: TypeScript dashboard -> Go binary with embedded static files.
#
# Build context: repo root (.)
# Usage:
#   docker build -f Dockerfile.trading-server -t trading-server:latest .
#   docker compose up trading-server

# --- Stage 1: Build Dashboard UI ---
FROM node:22-alpine AS ui-builder

WORKDIR /ui

COPY typescript/package.json typescript/package-lock.json ./
RUN npm ci

COPY typescript/ .
RUN npm run build

# --- Stage 2: Build Go binary (with embedded dashboard) ---
FROM golang:1.25-alpine AS builder

WORKDIR /build

RUN apk add --no-cache git

COPY golang/go.mod golang/go.sum ./
RUN go mod download

COPY golang/ .

# Embed the built dashboard into the Go binary.
COPY --from=ui-builder /ui/dist/ ./internal/dashboard/dist/

RUN CGO_ENABLED=0 GOOS=linux go build -o bin/server ./cmd/server

# --- Stage 3: Download Kraken CLI ---
FROM debian:bookworm-slim AS kraken-downloader

ARG TARGETARCH
RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates \
    && ARCH=$(case "$TARGETARCH" in arm64) echo "aarch64" ;; amd64) echo "x86_64" ;; *) echo "$TARGETARCH" ;; esac) \
    && curl -fsSL "https://github.com/krakenfx/kraken-cli/releases/latest/download/kraken-cli-${ARCH}-unknown-linux-gnu.tar.gz" \
       | tar -xzf - --strip-components=1 -C /usr/local/bin "kraken-cli-${ARCH}-unknown-linux-gnu/kraken" \
    && chmod +x /usr/local/bin/kraken

# --- Stage 4: Runtime ---
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates wget docker.io \
    && rm -rf /var/lib/apt/lists/*

COPY --from=kraken-downloader /usr/local/bin/kraken /usr/local/bin/kraken

WORKDIR /app

COPY --from=builder /build/bin/server ./server

EXPOSE 8091

CMD ["./server"]
